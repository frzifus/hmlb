{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  kubernetes: {
    managerFilePatterns: [
      '/clusters/.+\\.yaml$/',
    ],
  },
  flux: {
    managerFilePatterns: [
      '/clusters/.+\\.yaml$/',
    ],
  },
  customManagers: [
    {
      customType: 'regex',
      description: 'Cosign binary version in Tekton task scripts',
      managerFilePatterns: ['/clusters/.+\\.yaml$/'],
      matchStrings: [
        'COSIGN_VERSION="(?<currentValue>v[^"]+)"',
      ],
      depNameTemplate: 'sigstore/cosign',
      datasourceTemplate: 'github-releases',
      extractVersionTemplate: '^v(?<version>.*)$',
    },
    {
      customType: 'regex',
      description: 'Talos version in talconfig',
      managerFilePatterns: ['/infra/talconfig\\.yaml$/'],
      matchStrings: [
        'talosVersion: (?<currentValue>v\\S+)',
      ],
      depNameTemplate: 'siderolabs/talos',
      datasourceTemplate: 'github-releases',
    },
  ],
  packageRules: [
    {
      matchPackageNames: ['sigstore/cosign'],
      allowedVersions: '/^v2\\./',
    },
  ],
}
